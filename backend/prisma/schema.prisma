generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  admin
  driver
  student
}

enum VehicleStatus {
  offline
  waiting
  in_trip
  maintenance
}

enum TripStatus {
  requested
  assigned
  accepted
  in_progress
  completed
  cancelled
  no_show
}

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  phone        String?   @unique
  passwordHash String
  name         String
  role         UserRole
  status       String    @default("active")

  driverProfile  DriverProfile?
  studentProfile StudentProfile?

  assignedVehicles Vehicle[] @relation("VehicleAssignedDriver")

  studentTrips Trip[] @relation("TripStudent")
  driverTrips  Trip[] @relation("TripDriver")

  refreshTokens RefreshToken[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DriverProfile {
  userId      String @id
  user        User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  licenseNo   String?
  ratingAvg   Float  @default(0)
  ratingCount Int    @default(0)
}

model StudentProfile {
  userId     String @id
  user       User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  studentNo  String? @unique
  department String?
  hostel     String?
}

model Vehicle {
  id            String        @id @default(uuid())
  vehicleNumber String        @unique
  capacity      Int
  status        VehicleStatus @default(offline)
  batteryLevel  Int           @default(100)

  assignedDriverId String?
  assignedDriver   User?   @relation("VehicleAssignedDriver", fields: [assignedDriverId], references: [id], onDelete: SetNull)

  locations VehicleLocation[]
  trips      Trip[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VehicleLocation {
  id         BigInt   @id @default(autoincrement())
  vehicleId  String
  vehicle    Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  lat        Float
  lng        Float
  addressTxt String?
  recordedAt DateTime @default(now())

  @@index([vehicleId, recordedAt(sort: Desc)])
}

model Trip {
  id           String     @id @default(uuid())
  studentId    String
  student      User       @relation("TripStudent", fields: [studentId], references: [id], onDelete: Restrict)
  vehicleId    String?
  vehicle      Vehicle?   @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  driverId     String?
  driver       User?      @relation("TripDriver", fields: [driverId], references: [id], onDelete: SetNull)

  startLat     Float
  startLng     Float
  startAddress String?
  endLat       Float
  endLng       Float
  endAddress   String?

  status      TripStatus @default(requested)
  requestedAt DateTime   @default(now())
  acceptedAt  DateTime?
  startedAt   DateTime?
  completedAt DateTime?
  cancelledAt DateTime?

  otpCode String?

  events   TripEvent[]
  feedback Feedback?

  @@index([studentId, requestedAt(sort: Desc)])
  @@index([driverId, requestedAt(sort: Desc)])
  @@index([status])
}

model TripEvent {
  id        BigInt   @id @default(autoincrement())
  tripId    String
  trip      Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  type      String
  payload   Json?
  createdAt DateTime @default(now())

  @@index([tripId, createdAt(sort: Desc)])
}

model Feedback {
  id        String   @id @default(uuid())
  tripId    String   @unique
  trip      Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  rating    Int
  comment   String?
  createdAt DateTime @default(now())
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

