{
  "name": "university-transport-app",
  "version": "1.0.0",
  "type": "module",
  "description": "University Transportation Management System for Eco-Friendly Auto Rickshaws",
  "main": "index.js",
  "scripts": {
    "dev": "concurrently \"npm run docker:up\" \"npm run backend:dev\" \"npm run frontend:dev\"",
    "start": "npm run dev",
    "frontend:dev": "vite",
    "backend:dev": "npm --prefix backend run dev",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "db:migrate": "npm --prefix backend run prisma:migrate",
    "db:seed": "npm --prefix backend run prisma:seed",
    "db:studio": "npm --prefix backend run prisma:studio",
    "build": "vite build && npm --prefix backend run build",
    "lint": "eslint . --ext js,jsx,ts,tsx",
    "lint:fix": "eslint . --ext js,jsx,ts,tsx --fix",
    "test": "vitest"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.87.4",
    "axios": "^1.3.4",
    "date-fns": "^2.29.3",
    "dotenv": "^17.2.3",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.263.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.43.5",
    "react-hot-toast": "^2.4.0",
    "react-leaflet": "^4.2.1",
    "react-router-dom": "^6.8.1",
    "recharts": "^3.5.0",
    "socket.io-client": "^4.8.1",
    "vite-plugin-pwa": "^1.1.0",
    "zustand": "^4.3.6"
  },
  "devDependencies": {
    "@types/react": "^18.0.28",
    "@types/react-dom": "^18.0.11",
    "@vitejs/plugin-react": "^3.1.0",
    "autoprefixer": "^10.4.14",
    "baseline-browser-mapping": "^2.10.12",
    "concurrently": "^9.2.1",
    "eslint": "^8.36.0",
    "eslint-plugin-react": "^7.32.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.3.4",
    "postcss": "^8.4.21",
    "tailwindcss": "^3.2.7",
    "typescript": "^4.9.5",
    "vite": "^4.1.4"
  },
  "keywords": [
    "transportation",
    "university",
    "auto-rickshaw",
    "eco-friendly",
    "react"
  ],
  "author": "South Asian University",
  "license": "MIT"
}
